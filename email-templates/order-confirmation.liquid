{% capture email_title %}{% if has_pending_payment %}Thank you for your order!{% else %}Thank you for your purchase!{% endif %}{% endcapture %}

{% capture email_body %}{% if has_pending_payment %}{% if buyer_action_required %}You'll get a confirmation email after completing your payment.{% else %}Your payment is being processed. You'll get an email when your order is confirmed.{% endif %}{% else %}{% if requires_shipping %}{% case delivery_method %}{% when 'pick-up' %}You'll receive an email when your order is ready for pickup.{% when 'local' %}Hi {{ customer.first_name }}, we're getting your order ready for delivery.{% else %}We're getting your order ready to be shipped. We will notify you when it has been sent. <strong>Any PRE-ORDER items will be shipped once arrived to us at HYPEHEAT!</strong>{% endcase %}{% if consolidated_estimated_delivery_time %}<br>Estimated delivery <strong>{{ consolidated_estimated_delivery_time }}</strong>{% endif %}{% endif %}{% endif %}{% endcapture %}

<!DOCTYPE html>
<html lang="en">
<head>
  <title>{{ email_title }}</title>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width">
  <link rel="stylesheet" type="text/css" href="/assets/notifications/styles.css">
  <style>
    /* === HYPEHEAT Neon-Noir Email === */
    body, .body { background-color: #000000 !important; color: #cccccc !important; }
    .body { border-color: #000000 !important; }
    * { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif !important; }

    .header, .header__cell { background-color: #000000 !important; }
    .content, .content__cell, .section, .section__cell, .container { background-color: #000000 !important; }
    .footer, .footer__cell { background-color: #000000 !important; }
    .row { background-color: transparent !important; }

    h1, h2, .shop-name__text, .shop-name__text a { color: #ffffff !important; text-transform: uppercase !important; letter-spacing: 3px !important; font-weight: 700 !important; }
    h3 { color: #ff3131 !important; text-transform: uppercase !important; letter-spacing: 1.5px !important; font-weight: 600 !important; }
    h4 { color: #ff3131 !important; text-transform: uppercase !important; letter-spacing: 1px !important; font-size: 13px !important; }
    p, td, span, div { color: #cccccc !important; }

    a, a:hover, a:active, a:visited { color: #ff3131 !important; }
    .button__cell { background: #ff3131 !important; border-radius: 0 !important; }
    .button__text, .button__text:hover, .button__text:active, .button__text:visited { color: #ffffff !important; text-transform: uppercase !important; letter-spacing: 2px !important; font-weight: 700 !important; font-size: 13px !important; }

    .order-number__text, .po-number__text { color: #888888 !important; }
    .order-list__item-title { color: #ffffff !important; font-weight: 600 !important; }
    .order-list__item-variant { color: #999999 !important; }
    .order-list__item-price { color: #ffffff !important; font-weight: 600 !important; }
    .order-list__item-original-price { color: #666666 !important; }
    .order-list__item__cell { border-bottom: 1px solid #1a1a1a !important; }
    .order-list__product-image { border-radius: 4px !important; border: 1px solid #1a1a1a !important; }
    .order-list__no-image-cell { background-color: #1a1a1a !important; border-radius: 4px !important; }
    .order-list__item-discount-allocation span { color: #ff3131 !important; }

    .subtotal-line__title { color: #888888 !important; }
    .subtotal-line__value { color: #ffffff !important; }
    .footer p, .footer td, .footer span { color: #666666 !important; font-size: 12px !important; }
    .footer a { color: #ff3131 !important; }

    @media only screen and (max-width: 600px) {
      .body, .header, .header__cell, .content, .content__cell,
      .section, .section__cell, .container, .footer, .footer__cell { background-color: #000000 !important; }
    }
  </style>
</head>

<body style="background-color:#000; margin:0; padding:0;">
<table class="body" style="background-color:#000; border-color:#000;">
<tr><td>

  <!-- ====== HEADER ====== -->
  <table class="header row" style="background:#000; border-bottom:2px solid #ff3131;">
    <tr><td class="header__cell" style="background:#000;">
      <center>
        <table class="container" style="background:#000;">
          <tr><td>
            <table class="row">
              <tr>
                <td class="shop-name__cell">
                  {%- if shop.email_logo_url -%}
                    <img src="{{ shop.email_logo_url }}" alt="{{ shop.name }}" width="{{ shop.email_logo_width }}">
                  {%- else -%}
                    <h1 class="shop-name__text" style="color:#fff; text-transform:uppercase; letter-spacing:3px; font-weight:700;">
                      <a href="{{ shop.url }}" style="color:#fff; text-decoration:none;">{{ shop.name }}</a>
                    </h1>
                  {%- endif -%}
                </td>
                <td>
                  <span class="order-number__text" style="color:#888;">Order {{ order_name }}</span>
                  {%- if po_number -%}<br><span class="po-number__text" style="color:#888;">PO #{{ po_number }}</span>{%- endif -%}
                </td>
              </tr>
            </table>
          </td></tr>
        </table>
      </center>
    </td></tr>
  </table>

  <!-- ====== THANK YOU + CTA ====== -->
  <table class="row content" style="background:#000;">
    <tr><td class="content__cell" style="background:#000;">
      <center>
        <table class="container" style="background:#000;">
          <tr><td>
            <h2 style="color:#fff; text-transform:uppercase; letter-spacing:2px; font-weight:700;">{{ email_title }}</h2>
            <p style="color:#ccc;">{{ email_body }}</p>

            {% if order_status_url %}
              <table class="row actions">
                <tr><td class="empty-line">&nbsp;</td></tr>
                <tr><td class="actions__cell">
                  <table class="button main-action-cell">
                    <tr><td class="button__cell" style="background:#ff3131; border-radius:0;">
                      <a href="{{ order_status_url }}" class="button__text" style="color:#fff; text-transform:uppercase; letter-spacing:2px; font-weight:700; font-size:13px; text-decoration:none;">View your order</a>
                    </td></tr>
                  </table>
                  {% if shop.url %}
                    <table class="link secondary-action-cell">
                      <tr><td class="link__cell" style="color:#888;">or <a href="{{ shop.url }}" style="color:#ff3131;">Visit our store</a></td></tr>
                    </table>
                  {% endif %}
                </td></tr>
              </table>
            {% endif %}
          </td></tr>
        </table>
      </center>
    </td></tr>
  </table>

  <!-- ====== ORDER SUMMARY ====== -->
  <table class="row section" style="background:#000;">
    <tr><td class="section__cell" style="background:#000;">
      <center>
        <table class="container" style="background:#000;">
          <tr><td>
            <h3 style="color:#ff3131; text-transform:uppercase; letter-spacing:1.5px;">Order summary</h3>
          </td></tr>
        </table>
        <table class="container" style="background:#000;">
          <tr><td>

            <!-- Line items -->
            <table class="row">
              {% for line in subtotal_line_items %}
                <tr class="order-list__item">
                  <td class="order-list__item__cell" style="border-bottom:1px solid #1a1a1a; padding:15px 0;">
                    <table>
                      <tr>
                        <td class="order-list__image-cell" style="width:60px; vertical-align:top;">
                          {% if line.image %}
                            <img src="{{ line | img_url: 'compact_cropped' }}" width="60" height="60" style="border-radius:4px; border:1px solid #1a1a1a; display:block;" />
                          {% else %}
                            <div style="width:60px; height:60px; background:#1a1a1a; border-radius:4px;"></div>
                          {% endif %}
                        </td>
                        <td class="order-list__product-description-cell" style="padding-left:12px; vertical-align:top;">
                          <span style="color:#fff; font-weight:600;">
                            {{ line.title }}&nbsp;&times;&nbsp;{{ line.quantity }}
                          </span><br/>
                          {% if line.variant.title != 'Default Title' %}
                            <span style="color:#999; font-size:13px;">{{ line.variant.title }}</span><br/>
                          {% endif %}
                          {% if line.selling_plan_allocation %}
                            <span style="color:#999; font-size:13px;">{{ line.selling_plan_allocation.selling_plan.name }}</span><br/>
                          {% endif %}
                          {% if line.discount_allocations %}
                            {% for discount_allocation in line.discount_allocations %}
                              {% if discount_allocation.discount_application.target_selection != 'all' %}
                                <span style="color:#ff3131; font-size:13px;">
                                  {{ discount_allocation.discount_application.title | upcase }} (-{{ discount_allocation.amount | money }})
                                </span><br/>
                              {% endif %}
                            {% endfor %}
                          {% endif %}
                        </td>
                        <td class="order-list__price-cell" style="vertical-align:top; text-align:right; white-space:nowrap;">
                          {% if line.original_line_price != line.final_line_price %}
                            <del style="color:#666;">{{ line.original_line_price | money }}</del><br/>
                          {% endif %}
                          <span style="color:#fff; font-weight:600;">
                            {% if line.final_line_price > 0 %}{{ line.final_line_price | money }}{% else %}Free{% endif %}
                          </span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              {% endfor %}
            </table>

            <!-- Subtotals -->
            <table class="row" style="border-top:1px solid #1a1a1a; margin-top:15px;">
              {% for discount_application in discount_applications %}
                {% if discount_application.target_selection == 'all' %}
                  <tr>
                    <td style="color:#888; padding:8px 0;">
                      Discount
                      <span style="color:#ff3131;">{{ discount_application.title | upcase }} (-{{ discount_application.total_allocated_amount | money }})</span>
                    </td>
                    <td style="color:#fff; text-align:right; padding:8px 0;">
                      <strong>-{{ discount_application.total_allocated_amount | money }}</strong>
                    </td>
                  </tr>
                {% endif %}
              {% endfor %}

              <tr>
                <td style="color:#888; padding:8px 0;">Subtotal</td>
                <td style="color:#fff; text-align:right; padding:8px 0;"><strong>{{ subtotal_price | money }}</strong></td>
              </tr>

              {% if delivery_method == 'pick-up' %}
                <tr>
                  <td style="color:#888; padding:8px 0;">Pickup</td>
                  <td style="color:#fff; text-align:right; padding:8px 0;"><strong>Free</strong></td>
                </tr>
              {% else %}
                {% for shipping_line in shipping_lines %}
                  <tr>
                    <td style="color:#888; padding:8px 0;">Shipping ({{ shipping_line.title }})</td>
                    <td style="color:#fff; text-align:right; padding:8px 0;">
                      <strong>{% if shipping_line.price > 0 %}{{ shipping_line.price | money }}{% else %}Free{% endif %}</strong>
                    </td>
                  </tr>
                {% endfor %}
              {% endif %}

              {% for tax_line in tax_lines %}
                <tr>
                  <td style="color:#888; padding:8px 0;">{{ tax_line.title }}</td>
                  <td style="color:#fff; text-align:right; padding:8px 0;"><strong>{{ tax_line.price | money }}</strong></td>
                </tr>
              {% endfor %}

              {% if current_total_duties %}
                <tr>
                  <td style="color:#888; padding:8px 0;">Duties</td>
                  <td style="color:#fff; text-align:right; padding:8px 0;"><strong>{{ current_total_duties | money }}</strong></td>
                </tr>
              {% endif %}

              {% if total_tip and total_tip > 0 %}
                <tr>
                  <td style="color:#888; padding:8px 0;">Tip</td>
                  <td style="color:#fff; text-align:right; padding:8px 0;"><strong>{{ total_tip | money }}</strong></td>
                </tr>
              {% endif %}
            </table>

            <!-- Total -->
            <table class="row" style="border-top:2px solid #ff3131; margin-top:4px;">
              <tr>
                <td style="color:#fff; padding:12px 0; font-size:16px; font-weight:700;">Total</td>
                <td style="color:#fff; text-align:right; padding:12px 0; font-size:16px; font-weight:700;">{{ total_price | money_with_currency }}</td>
              </tr>
            </table>

            {% if total_discounts > 0 %}
              <p style="color:#ff3131; margin:4px 0 0;">You saved {{ total_discounts | money }}</p>
            {% endif %}

            <!-- Payment info -->
            {% for transaction in transactions %}
              {% if transaction.status == "success" and transaction.kind == "capture" or transaction.kind == "sale" %}
                {% if transaction.payment_details.credit_card_company %}
                  <table class="row" style="margin-top:8px;">
                    <tr>
                      <td style="color:#888; padding:4px 0;">{{ transaction.payment_details.credit_card_company }} &bull;&bull;&bull;&bull; {{ transaction.payment_details.credit_card_last_four_digits }}</td>
                      <td style="color:#fff; text-align:right; padding:4px 0;"><strong>{{ transaction.amount | money }}</strong></td>
                    </tr>
                  </table>
                {% endif %}
              {% endif %}
            {% endfor %}

            {% if has_pending_payment %}
              <table class="row" style="margin-top:8px;">
                <tr>
                  <td style="color:#888; padding:4px 0;">Amount due</td>
                  <td style="color:#fff; text-align:right; padding:4px 0;"><strong>{{ total_outstanding | money_with_currency }}</strong></td>
                </tr>
              </table>
            {% endif %}

          </td></tr>
        </table>
      </center>
    </td></tr>
  </table>

  <!-- ====== CUSTOMER INFO ====== -->
  {% if requires_shipping and shipping_address %}
    <table class="row section" style="background:#000;">
      <tr><td class="section__cell" style="background:#000;">
        <center>
          <table class="container" style="background:#000;">
            <tr><td>
              <h3 style="color:#ff3131; text-transform:uppercase; letter-spacing:1.5px;">Customer information</h3>
            </td></tr>
          </table>
          <table class="container" style="background:#000;">
            <tr><td>
              <table class="row">
                <tr>
                  {% if shipping_address %}
                    <td style="vertical-align:top; padding-right:20px;">
                      <h4 style="color:#ff3131; text-transform:uppercase; letter-spacing:1px; font-size:13px;">Shipping address</h4>
                      <p style="color:#ccc;">
                        {{ shipping_address.name }}<br/>
                        {{ shipping_address.street }}<br/>
                        {{ shipping_address.city }}, {{ shipping_address.province }} {{ shipping_address.zip }}<br/>
                        {{ shipping_address.country }}
                      </p>
                    </td>
                  {% endif %}
                  {% if billing_address %}
                    <td style="vertical-align:top;">
                      <h4 style="color:#ff3131; text-transform:uppercase; letter-spacing:1px; font-size:13px;">Billing address</h4>
                      <p style="color:#ccc;">
                        {{ billing_address.name }}<br/>
                        {{ billing_address.street }}<br/>
                        {{ billing_address.city }}, {{ billing_address.province }} {{ billing_address.zip }}<br/>
                        {{ billing_address.country }}
                      </p>
                    </td>
                  {% endif %}
                </tr>
                <tr>
                  {% if shipping_address %}
                    <td style="vertical-align:top; padding-right:20px;">
                      <h4 style="color:#ff3131; text-transform:uppercase; letter-spacing:1px; font-size:13px;">Shipping method</h4>
                      <p style="color:#ccc;">{{ shipping_method.title }}</p>
                    </td>
                  {% endif %}
                  {% if billing_address %}
                    <td style="vertical-align:top;">
                      <h4 style="color:#ff3131; text-transform:uppercase; letter-spacing:1px; font-size:13px;">Payment method</h4>
                      {% for transaction in transactions %}
                        {% if transaction.status == "success" or transaction.status == "pending" %}
                          {% if transaction.kind == "capture" or transaction.kind == "sale" or transaction.kind == "authorization" %}
                            <p style="color:#ccc;">
                              {% if transaction.payment_details.credit_card_company %}
                                {{ transaction.payment_details.credit_card_company }} ending in {{ transaction.payment_details.credit_card_last_four_digits }} &mdash; <strong style="color:#fff;">{{ transaction.amount | money }}</strong>
                              {% elsif transaction.gateway_display_name == "Gift card" %}
                                Gift card ending in {{ transaction.payment_details.gift_card_last_four_digits }} &mdash; <strong style="color:#fff;">{{ transaction.amount | money }}</strong>
                              {% else %}
                                {{ transaction.gateway_display_name }} &mdash; <strong style="color:#fff;">{{ transaction.amount | money }}</strong>
                              {% endif %}
                            </p>
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    </td>
                  {% endif %}
                </tr>
              </table>
            </td></tr>
          </table>
        </center>
      </td></tr>
    </table>
  {% endif %}

  <!-- ====== FOOTER ====== -->
  <table class="row footer" style="background:#000; border-top:1px solid #1a1a1a;">
    <tr><td class="footer__cell" style="background:#000;">
      <center>
        <table class="container" style="background:#000;">
          <tr><td>
            <p style="color:#666; font-size:12px;">If you have any questions, reply to this email or contact us at <a href="mailto:{{ shop.email }}" style="color:#ff3131;">{{ shop.email }}</a></p>
          </td></tr>
        </table>
      </center>
    </td></tr>
  </table>

</td></tr>
</table>
</body>
</html>
